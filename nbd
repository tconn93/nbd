#!/usr/bin/env python3
"""
nbd — Hermes Fleet Orchestration Setup

Usage:
    nbd setup master            Set up as fleet master (interview-style)
    nbd setup node --master URL Set up as a worker node
    nbd status                  Show fleet config and status
    nbd service install         Install dashboard as a systemd user service
    nbd service uninstall       Remove the systemd service
"""

import argparse
import json
import os
import socket
import subprocess
import sys
import time
from pathlib import Path

HERMES_HOME = Path.home() / ".hermes"
FLEET_CONFIG = HERMES_HOME / "fleet_config.json"
PLUGIN_DIR = HERMES_HOME / "plugins" / "nbd"
SERVICE_NAME = "hermes-dashboard"
SERVICE_FILE = Path.home() / ".config" / "systemd" / "user" / f"{SERVICE_NAME}.service"


def _get_local_ip() -> str:
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("10.255.255.255", 1))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return "127.0.0.1"


def _save_config(cfg: dict):
    FLEET_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    FLEET_CONFIG.write_text(json.dumps(cfg, indent=2))


def _load_config() -> dict:
    if FLEET_CONFIG.exists():
        return json.loads(FLEET_CONFIG.read_text())
    return {"mode": None}


def _prompt(default: str = "") -> str:
    """Simple input with fallback."""
    try:
        return input().strip() or default
    except (EOFError, KeyboardInterrupt):
        return default


# ── Plugin Install ────────────────────────────────────────────────────────

def _find_plugin_src() -> Path | None:
    script_dir = Path(__file__).resolve().parent
    for c in [
        script_dir / "plugins" / "nbd",
        script_dir.parent / "plugins" / "nbd",
        Path.cwd() / "plugins" / "nbd",
    ]:
        if (c / "plugin.yaml").exists():
            return c
    return None


def _install_plugin():
    src = _find_plugin_src()
    if not src:
        print("  ❌ Cannot find plugin source. Run from the nbd repo directory.")
        return False

    dst = PLUGIN_DIR
    dst.mkdir(parents=True, exist_ok=True)

    for item in src.iterdir():
        if item.name == "dashboard":
            dd = dst / "dashboard"
            dd.mkdir(parents=True, exist_ok=True)
            (dd / "manifest.json").write_text((item / "manifest.json").read_text())
            (dd / "plugin_api.py").write_text((item / "plugin_api.py").read_text())
            (dd / "dist").mkdir(exist_ok=True)
            (dd / "dist" / "index.js").write_text((item / "dist" / "index.js").read_text())
        elif item.suffix in (".py", ".yaml", ".json", ".js", ".css", ".md"):
            (dst / item.name).write_text(item.read_text())

    print(f"  ✅ Plugin installed → {dst}")
    return True


# ── Config Setup ──────────────────────────────────────────────────────────

def _enable_plugin_in_config():
    import yaml
    config_path = HERMES_HOME / "config.yaml"
    if not config_path.exists():
        return False

    with open(config_path) as f:
        cfg = yaml.safe_load(f) or {}

    plugins = cfg.setdefault("plugins", {})
    enabled = plugins.setdefault("enabled", [])
    if not isinstance(enabled, list):
        enabled = []
    if "nbd" not in enabled:
        enabled.append("nbd")
    plugins["enabled"] = enabled
    cfg["plugins"] = plugins

    with open(config_path, "w") as f:
        yaml.dump(cfg, f, default_flow_style=False, sort_keys=False)
    print("  ✅ Plugin enabled in Hermes config")
    return True


# ── Database Setup ────────────────────────────────────────────────────────

def _setup_database() -> dict:
    """Ask user about database backend. Returns db config dict."""
    print("\n  ── Database Backend ──")
    print("  How should nbd store its data (nodes, sessions)?")
    print("")
    print("    [1] SQLite (default) — simple, no setup needed")
    print("    [2] Postgres — use an existing Postgres instance")
    print("    [3] Docker Postgres — auto-deploy a Postgres container")
    print("")
    print("  Choice [1]: ", end="", flush=True)

    choice = _prompt("1")

    if choice == "2":
        print("\n  Enter Postgres connection URL:")
        print("  Example: postgresql://user:pass@host:5432/nbd")
        print("  URL: ", end="", flush=True)
        url = _prompt()
        if url:
            print(f"  ✅ Using Postgres: {url[:40]}...")
            return {"backend": "postgres", "url": url}
        print("  ⚠️  No URL entered, falling back to SQLite")

    elif choice == "3":
        print("\n  🐘 Deploying Postgres via Docker...")
        pw = os.urandom(16).hex()
        try:
            subprocess.run(
                ["docker", "run", "-d",
                 "--name", "nbd-db",
                 "-e", f"POSTGRES_PASSWORD={pw}",
                 "-e", "POSTGRES_DB=nbd",
                 "-p", "5432:5432",
                 "-v", "nbd-db-data:/var/lib/postgresql/data",
                 "postgres:16-alpine"],
                check=True, capture_output=True, text=True,
            )
            url = f"postgresql://postgres:{pw}@127.0.0.1:5432/nbd"
            print(f"  ✅ Postgres container started!")
            print(f"  ✅ Connection: postgresql://postgres:****@127.0.0.1:5432/nbd")
            return {"backend": "docker-postgres", "url": url, "password": pw}
        except FileNotFoundError:
            print("  ❌ Docker not found. Install Docker or choose SQLite.")
        except subprocess.CalledProcessError as e:
            print(f"  ❌ Docker failed: {e.stderr.strip() or 'container may already exist'}")
            print("  Run: docker rm -f nbd-db && nbd setup master")

    print("  ✅ Using SQLite")
    return {"backend": "sqlite"}


# ── Service Install ───────────────────────────────────────────────────────

def _install_service():
    """Install hermes-dashboard as a systemd user service."""
    print("\n  ── Systemd Service ──")

    service_content = f"""\
[Unit]
Description=nbd Hermes Fleet Dashboard
After=network.target

[Service]
Type=simple
ExecStart={sys.executable} -m hermes dashboard --host 0.0.0.0 --port 9119
Restart=always
RestartSec=5
Environment=NBD_DATABASE_URL={_load_config().get("db_url", "")}

[Install]
WantedBy=default.target
"""
    SERVICE_FILE.parent.mkdir(parents=True, exist_ok=True)
    SERVICE_FILE.write_text(service_content)

    try:
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=True, capture_output=True)
        subprocess.run(["systemctl", "--user", "enable", SERVICE_NAME], check=True, capture_output=True)
        subprocess.run(["systemctl", "--user", "start", SERVICE_NAME], check=True, capture_output=True)

        # Enable linger so user services survive logout
        subprocess.run(["loginctl", "enable-linger", os.environ.get("USER", "tcon")],
                       check=False, capture_output=True)

        print(f"  ✅ Service installed: {SERVICE_NAME}")
        print(f"  ✅ Status: systemctl --user status {SERVICE_NAME}")
    except subprocess.CalledProcessError as e:
        print(f"  ❌ Service install failed: {e.stderr.decode()[:200]}")
        print("  You can start manually: hermes dashboard --host 0.0.0.0 --port 9119")
        return False

    return True


def cmd_service_install():
    """Install the dashboard as a systemd service."""
    _install_service()


def cmd_service_uninstall():
    """Remove the systemd service."""
    if SERVICE_FILE.exists():
        subprocess.run(["systemctl", "--user", "stop", SERVICE_NAME], check=False)
        subprocess.run(["systemctl", "--user", "disable", SERVICE_NAME], check=False)
        SERVICE_FILE.unlink()
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=False)
        print(f"  ✅ Service {SERVICE_NAME} removed")
    else:
        print("  ℹ️  Service not installed")


# ── Auth Setup ────────────────────────────────────────────────────────────

def _setup_auth():
    """Configure dashboard basic auth."""
    result = subprocess.run(
        ["hermes", "config", "get", "dashboard.basic_auth.username"],
        capture_output=True, text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        subprocess.run(["hermes", "config", "set", "dashboard.basic_auth.username", "admin"],
                       capture_output=True)
        hash_result = subprocess.run(
            ["python3", "-c",
             "from plugins.dashboard_auth.basic import hash_password; print(hash_password('hermes'))"],
            capture_output=True, text=True,
        )
        if hash_result.returncode == 0:
            subprocess.run(
                ["hermes", "config", "set", "dashboard.basic_auth.password_hash",
                 hash_result.stdout.strip()],
                capture_output=True,
            )
        print("  ✅ Login: admin / hermes")
    else:
        print("  ✅ Auth already configured")


# ── Setup Commands ───────────────────────────────────────────────────────

def cmd_setup_master():
    """Interview-style master setup."""
    print("\n" + "=" * 56)
    print("  nbd — Fleet Master Setup")
    print("=" * 56)

    # 1. Plugin
    print("\n📦 Step 1/5: Installing plugin...")
    if not _install_plugin():
        sys.exit(1)

    # 2. Enable
    print("\n🔧 Step 2/5: Enabling plugin in Hermes...")
    _enable_plugin_in_config()

    # 3. Database
    print("\n🗄️  Step 3/5: Database setup...")
    db_cfg = _setup_database()

    # 4. Auth
    print("\n🔑 Step 4/5: Dashboard authentication...")
    _setup_auth()

    # 5. Service
    print("\n🚀 Step 5/5: Service installation...")
    svc_ok = _install_service()

    # Summary
    local_ip = _get_local_ip()
    cfg = {
        "mode": "master",
        "db": db_cfg,
        "dashboard_url": f"http://{local_ip}:9119",
        "fleet_api": f"http://127.0.0.1:9119/api/plugins/nbd",
    }
    if db_cfg.get("url"):
        cfg["db_url"] = db_cfg["url"]
    _save_config(cfg)

    print("\n" + "=" * 56)
    print("  ✅ Master is ready!")
    print(f"  Dashboard:  http://{local_ip}:9119")
    print(f"  Login:      admin / hermes")
    print(f"  Fleet tab:  Dashboard → Fleet")
    print(f"  Database:   {db_cfg['backend']}")
    print(f"  Service:    {'✅ Running' if svc_ok else '⚠️  Manual start needed'}")
    print("=" * 56)
    print("\n📌 Connect workers:")
    print(f"  nbd setup node --master http://{local_ip}:9119\n")


def cmd_generate_token(hours: int = 24, desc: str = ""):
    """Generate a registration token valid for N hours."""
    print("\n  Generating registration token...")
    import urllib.request
    payload = json.dumps({"hours": hours, "description": desc}).encode()
    try:
        cfg = _load_config()
        api_url = cfg.get("fleet_api", "http://127.0.0.1:9119/api/plugins/nbd")
        req = urllib.request.Request(
            f"{api_url}/tokens/generate",
            data=payload,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())

        print(f"\n  ✅ Token generated!")
        print(f"  Token:     {data['token']}")
        print(f"  Expires:   {data['expires_at'][:19]}")
        print(f"  Valid for: {hours}h")
        print(f"\n  📌 Give this command to the node agent:\n")
        print(f"    {data['command']}\n")
    except Exception as e:
        print(f"  ❌ Failed: {e}")


def cmd_setup_node(master_url: str = None, token: str = None):
    """Configure as a fleet node."""
    print("\n" + "=" * 56)
    print("  nbd — Fleet Node Setup")
    print("=" * 56)

    if not master_url:
        print("\n  Master dashboard URL: ", end="", flush=True)
        master_url = _prompt()
        if not master_url:
            print("  ❌ Master URL required")
            sys.exit(1)
    master_url = master_url.rstrip("/")

    default_name = f"node-{socket.gethostname()}"
    print(f"\n  Node name [{default_name}]: ", end="", flush=True)
    node_name = _prompt(default_name)

    print(f"  Port for hermes proxy [8080]: ", end="", flush=True)
    proxy_port = _prompt("8080")

    local_ip = _get_local_ip()
    cfg = {
        "mode": "node",
        "master_url": master_url,
        "node_name": node_name,
        "proxy_url": f"http://{local_ip}:{proxy_port}",
        "proxy_port": int(proxy_port),
    }
    _save_config(cfg)

    print(f"\n🚀 Starting hermes proxy on port {proxy_port}...")
    subprocess.Popen(
        ["hermes", "proxy", "--port", proxy_port, "--host", "0.0.0.0"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    print(f"  ✅ Proxy running at {cfg['proxy_url']}")

    print(f"  Registering with master...")
    import urllib.request
    payload_dict = {
        "node_id": f"node-{socket.gethostname()}",
        "name": node_name,
        "api_url": cfg["proxy_url"],
    }
    if token:
        payload_dict["token"] = token
    payload = json.dumps(payload_dict).encode()

    try:
        req = urllib.request.Request(
            f"{master_url}/api/plugins/nbd/nodes/register",
            data=payload,
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            result = json.loads(resp.read())
            print(f"  ✅ Registered! ID: {result.get('node_id', 'unknown')}")
    except Exception as e:
        print(f"  ⚠️  Registration failed: {e}")
        print(f"  Manual: curl -X POST {master_url}/api/plugins/nbd/nodes/register \\")
        print(f'    -H "Content-Type: application/json" \\')
        print(f'    -d \'{{"api_url": "{cfg["proxy_url"]}", "name": "{node_name}"}}\'')

    print(f"\n✅ Node setup complete!\n")


def cmd_status():
    """Show fleet status."""
    cfg = _load_config()
    mode = cfg.get("mode", "not configured")
    print(f"\nnbd Fleet Status")
    print(f"  Mode: {mode}")

    if mode == "master":
        print(f"  Dashboard: {cfg.get('dashboard_url', 'unknown')}")
        print(f"  Database:  {cfg.get('db', {}).get('backend', 'unknown')}")
        import urllib.request
        try:
            resp = urllib.request.urlopen(f"{cfg['fleet_api']}/nodes", timeout=3)
            data = json.loads(resp.read())
            print(f"  Nodes:     {data.get('count', 0)} connected")
            for n in data.get("nodes", []):
                print(f"    · {n.get('name', n['id']):25s} [{n.get('status', '?')}]")
        except Exception:
            print("  ⚠️  Dashboard not reachable")
    elif mode == "node":
        print(f"  Master: {cfg.get('master_url', 'unknown')}")
        print(f"  Proxy:  {cfg.get('proxy_url', 'unknown')}")
    else:
        print("  Run: nbd setup master  or  nbd setup node --master <url>")


def main():
    parser = argparse.ArgumentParser(description="nbd — Hermes Fleet Orchestration")
    sub = parser.add_subparsers(dest="command")

    setup_p = sub.add_parser("setup", help="Set up as master or node")
    setup_p.add_argument("role", nargs="?", choices=["master", "node"])
    setup_p.add_argument("--master", "-m", help="Master URL (for node setup)")
    setup_p.add_argument("--token", "-t", help="Registration token (from master generate-token)")

    gen_p = sub.add_parser("generate-token", help="Generate a time-limited registration token (24h)")
    gen_p.add_argument("--hours", type=int, default=24, help="Token validity in hours")
    gen_p.add_argument("--desc", default="", help="Description for the token")

    svc_p = sub.add_parser("service", help="Manage systemd service")
    svc_p.add_argument("action", choices=["install", "uninstall"])

    sub.add_parser("status", help="Show fleet status")

    args = parser.parse_args()

    if args.command == "setup":
        if args.role == "master":
            cmd_setup_master()
        elif args.role == "node":
            cmd_setup_node(args.master, args.token)
        else:
            print("Usage: nbd setup master | nbd setup node --master <url>")
    elif args.command == "generate-token":
        cmd_generate_token(hours=args.hours, desc=args.desc)
    elif args.command == "service":
        if args.action == "install":
            cmd_service_install()
        else:
            cmd_service_uninstall()
    elif args.command == "status":
        cmd_status()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
